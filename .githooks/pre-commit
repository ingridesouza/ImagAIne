#!/usr/bin/env bash
# =============================================================================
# ImagAIne — Pre-commit hook (SDD enforcement)
#
# Verifica se a spec OpenAPI e os tipos TypeScript estao sincronizados.
# Se arquivos de serializer/view foram alterados, a spec DEVE estar atualizada.
#
# Instalacao: git config core.hooksPath .githooks
# =============================================================================

set -euo pipefail

YELLOW='\033[0;33m'
RED='\033[0;31m'
GREEN='\033[0;32m'
RESET='\033[0m'

# Arquivos staged
STAGED=$(git diff --cached --name-only --diff-filter=ACM)

# Checar se algum arquivo de contrato foi alterado
CONTRACT_CHANGED=false
for file in $STAGED; do
    case "$file" in
        backend/*/serializers.py|backend/*/views.py|backend/*/urls.py|backend/*/models.py)
            CONTRACT_CHANGED=true
            break
            ;;
    esac
done

if [ "$CONTRACT_CHANGED" = true ]; then
    echo -e "${YELLOW}[SDD] Arquivos de contrato alterados. Verificando spec...${RESET}"

    # Verificar se schema.yaml e schema.d.ts estao nos staged files
    SPEC_STAGED=false
    TYPES_STAGED=false

    for file in $STAGED; do
        case "$file" in
            frontend/openapi-schema.yaml) SPEC_STAGED=true ;;
            frontend/src/api/schema.d.ts) TYPES_STAGED=true ;;
        esac
    done

    if [ "$SPEC_STAGED" = false ] || [ "$TYPES_STAGED" = false ]; then
        echo ""
        echo -e "${RED}[SDD] ERRO: Voce alterou serializers/views/urls/models mas NAO atualizou a spec.${RESET}"
        echo ""
        echo "  Arquivos de contrato alterados:"
        for file in $STAGED; do
            case "$file" in
                backend/*/serializers.py|backend/*/views.py|backend/*/urls.py|backend/*/models.py)
                    echo "    - $file"
                    ;;
            esac
        done
        echo ""
        echo "  Faltando no commit:"
        if [ "$SPEC_STAGED" = false ]; then
            echo -e "    ${RED}✗ frontend/openapi-schema.yaml${RESET}"
        fi
        if [ "$TYPES_STAGED" = false ]; then
            echo -e "    ${RED}✗ frontend/src/api/schema.d.ts${RESET}"
        fi
        echo ""
        echo "  Rode antes de commitar:"
        echo -e "    ${YELLOW}make sync${RESET}"
        echo "    git add frontend/openapi-schema.yaml frontend/src/api/schema.d.ts"
        echo ""
        exit 1
    fi

    echo -e "${GREEN}[SDD] OK — Spec e tipos atualizados no commit.${RESET}"
fi

exit 0
